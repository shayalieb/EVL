generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  firstName      String
  lastName       String
  email          String      @unique
  phone          String?
  passwordHash   String?
  googleId       String?     @unique
  // App operators, not signup-settable. isPlatformAdmin is grantable/revocable
  // by existing admins (server/src/routes/admin.js); isPlatformOwner is the
  // one admin who can never be revoked by anyone else — flipped manually,
  // never through any API.
  isPlatformAdmin Boolean    @default(false)
  isPlatformOwner Boolean    @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  membership     Membership?
  passwordResetTokens PasswordResetToken[]
  supportNotes   SupportNote[]
}

model Account {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  disabledAt     DateTime?       // set by a platform admin; blocks all account access when non-null
  memberships    Membership[]
  emailThreads   EmailThread[]
  eventDocuments EventDocument[]
  bookingDocuments BookingDocument[]
  contracts      Contract[]
  invoices       Invoice[]
  accountData    AccountData?
  supportThreads SupportThread[]

  // Stripe Connect (Express) — set once onboarding starts. The three
  // booleans are a local cache of the connected Account object, synced by
  // account.updated webhooks (server/src/routes/stripeWebhooks.js) and by a
  // manual refresh right after the onboarding redirect back into the app
  // (server/src/routes/billing.js), since webhooks can lag that redirect by
  // a few seconds. chargesEnabled (not just stripeAccountId being set) is
  // what every invoice-sending code path actually checks, since Stripe can
  // flag a previously-connected account and revoke it later.
  stripeAccountId        String?  @unique
  stripeDetailsSubmitted Boolean  @default(false)
  stripeChargesEnabled   Boolean  @default(false)
  stripePayoutsEnabled   Boolean  @default(false)

  // Running invoice-numbering sequence and sticky footer memo — carried
  // into each new invoice's composer as a default, and advanced/updated
  // whenever an invoice is created or edited with an explicit number/memo.
  // See server/src/routes/invoices.js's GET /next-number.
  nextInvoiceNumber  Int     @default(1)
  defaultInvoiceMemo String? @db.Text
}

model Membership {
  id          String   @id @default(cuid())
  role        String   @default("member") // 'owner' | 'admin' | 'member'
  permissions Json     @default("{}")
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
}

// Raw token is emailed to the user and never stored — only its hash, so a
// DB read alone can't be replayed to take over an account (same reasoning
// as passwordHash on User).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
}

// Contractors/events themselves still live in the frontend's localStorage
// (see server/README.md) — eventId/contractorId below are opaque strings
// from that blob, not real FKs. accountId is the only real relation, and is
// what scopes every read so different EVL accounts never see each other's
// threads.
model EmailThread {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  eventId         String
  contractorId    String
  contractorEmail String

  // "reply+<this.id>@<RESEND_INBOUND_DOMAIN>" — null until a domain is
  // configured. Set once and never recomputed, since a contractor's mail
  // client keeps replying to whatever address a past email actually had.
  replyToAlias    String?
  subjectHint     String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())

  messages        EmailMessage[]

  @@unique([accountId, eventId, contractorId])
  @@index([accountId])
}

model EmailMessage {
  id              String      @id @default(cuid())
  threadId        String
  thread          EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction       String      // 'outbound' | 'inbound'
  fromAddress     String
  toAddress       String
  subject         String
  body            String      @db.Text

  templateId      String?
  sentByUserId    String?
  resendMessageId String?     @unique
  inReplyTo       String?
  references      String?

  readAt          DateTime?   // inbound-only; null = unread
  createdAt       DateTime    @default(now())

  @@index([threadId, createdAt])
}

// The team's shared contractors/clients/events/bookings/settings, as a
// single JSON blob per account (mirrors the shape the frontend used to keep
// in localStorage, keyed by userId — now shared across every member of the
// account instead of siloed per browser).
model AccountData {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime @updatedAt
}

// Two-way support conversation between an account and the platform admin —
// deliberately mirrors EmailThread/EmailMessage's shape (direction as a
// plain string, accountId scoping, lastMessageAt/readAt) since that's this
// codebase's established pattern for threaded messages.
model SupportThread {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  subject       String
  status        String   @default("open") // 'open' | 'closed'
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  // "reply+support-<this.id>@<RESEND_INBOUND_DOMAIN>" — null until a domain
  // is configured. Set once and never recomputed, same reasoning as
  // EmailThread.replyToAlias above.
  replyToAlias  String?

  messages      SupportMessage[]
  notes         SupportNote[]

  @@index([accountId])
}

model SupportMessage {
  id              String        @id @default(cuid())
  threadId        String
  thread          SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction       String        // 'user' | 'admin'
  senderUserId    String
  body            String        @db.Text

  resendMessageId String?       @unique
  attachments     SupportAttachment[]

  readAt          DateTime?     // null = unread by the other side
  createdAt       DateTime      @default(now())

  @@index([threadId, createdAt])
}

model SupportAttachment {
  id          String         @id @default(cuid())
  messageId   String
  message     SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  filename    String
  contentType String
  size        Int
  data        Bytes

  createdAt   DateTime       @default(now())

  @@index([messageId])
}

// Admin-only annotations on a support thread — never sent to or visible by
// the account. Kept as its own model rather than a flag on SupportMessage so
// the customer-facing route (server/src/routes/support.js) can't leak these
// just by forgetting a filter.
model SupportNote {
  id           String        @id @default(cuid())
  threadId     String
  thread       SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorUserId String
  author       User          @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  body         String        @db.Text

  createdAt    DateTime      @default(now())

  @@index([threadId, createdAt])
}

// Uploaded reference documents (stage plots, floor plans, contracts) for an
// event's prep sheet. Stored directly in Postgres (Bytes) rather than an
// external object store — no new service to configure, fine at this scale.
model EventDocument {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  eventId     String   // opaque localStorage id, same non-FK pattern as EmailThread
  filename    String
  contentType String
  size        Int
  data        Bytes

  createdAt   DateTime @default(now())

  @@index([accountId, eventId])
}

// Uploaded files for a booking's Proposal/Contract tabs — same non-FK
// bookingId pattern as EventDocument.eventId above. category distinguishes
// which tab a file belongs to.
model BookingDocument {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  bookingId   String   // opaque localStorage id, same non-FK pattern as EventDocument.eventId
  category    String   // 'proposal' | 'contract'
  filename    String
  contentType String
  size        Int
  data        Bytes

  createdAt   DateTime @default(now())

  @@index([accountId, bookingId])
}

// A booking's proposal, moved into a contract for signature. snapshot is
// frozen at send time (business/client/event details + line items) so later
// edits to the booking or proposal don't retroactively change a contract
// that's already out for signature. Client and owner each get their own
// one-time sign token — only its hash is stored, same reasoning as
// PasswordResetToken (a DB read alone can't be replayed into a signature).
// The owner's token lets them sign from the emailed link even when signed
// out (e.g. on the move); they can also sign in-app via requireAuth routes,
// whichever comes first.
model Contract {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  bookingId       String   // opaque localStorage id, same non-FK pattern as EventDocument.eventId

  snapshot        Json
  // Unlike everything in snapshot (frozen at send time), terms stays live —
  // editable at any point in the contract's lifecycle, independent of
  // status, and always read fresh when rendering/viewing the PDF.
  terms           String?  @db.Text
  status          String   @default("sent") // 'sent' | 'client_signed' | 'owner_signed' | 'fully_signed'

  recipientEmail  String
  recipientName   String?
  ownerEmail      String

  clientTokenHash String?  @unique
  ownerTokenHash  String?  @unique

  clientSignedAt       DateTime?
  clientSignatureName  String?
  clientSignatureImage String? @db.Text

  ownerSignedAt        DateTime?
  ownerSignatureName   String?
  ownerSignatureImage  String? @db.Text

  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([accountId, bookingId])
}

// A billable invoice for a booking, paid online via Stripe Connect directly
// into the account's own connected Stripe account (see Account.stripeAccountId
// above) — GigWorks never touches the funds. Unlike Contract (frozen and
// sent in one step), an invoice has a real draft stage: snapshot/dueDate/memo
// stay editable while status is 'draft', then lock once sent, mirroring the
// spirit of Contract's frozen snapshot without a separate always-live field
// (there's no "terms" equivalent an invoice needs to keep editing post-send).
// A booking can have several invoices over time (e.g. deposit + balance), so
// reads are always a list, unlike Contract's effective one-per-booking.
// No stored total — always computed from snapshot.lineItems via
// computeOfferingsTotal() (src/lib/offerings.js), same as Proposal never
// storing a redundant total either.
model Invoice {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  bookingId       String   // opaque localStorage id, same non-FK pattern as Contract.bookingId

  // Editable by the owner; defaults to Account.nextInvoiceNumber at create
  // time. Not DB-unique — editing it to fix/jump the sequence is expected,
  // and enforcing uniqueness would turn that into an error-prone edit.
  number          Int?
  snapshot        Json     // { businessInfo, client, lineItems: Offering[] }
  dueDate         DateTime?
  memo            String?  @db.Text

  status          String   @default("draft") // 'draft' | 'sent' | 'partial' | 'paid' | 'void'
  // How much of the total has been recorded as paid — set to the full total
  // automatically by the Stripe webhook, or entered by hand when marking an
  // offline (cash/check/etc.) payment. Null/0 while still 'sent'.
  paidAmount      Float?
  // Only set by the manual "Accept Payment" popover (mark-payment status
  // 'paid') — Stripe's own webhook payments leave these null since the
  // method/reference are implicit (always a card, via the pay link).
  paymentMethod    String? // 'ach' | 'check' | 'card' | 'other'
  paymentReference String? // check number, only meaningful when method is 'check'
  paymentMemo      String? @db.Text // internal note about the payment, separate from the client-facing `memo` above

  recipientEmail  String
  recipientName   String?
  ownerEmail      String

  // Raw token emailed once, only its hash persisted — same reasoning as
  // Contract's clientTokenHash/PasswordResetToken.tokenHash. Only one role
  // (the client) ever needs a pay link, unlike Contract's client+owner pair.
  payTokenHash    String?  @unique

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?

  sentAt          DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?
  receiptSentAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([accountId, bookingId])
}
