generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  firstName      String
  lastName       String
  email          String      @unique
  phone          String?
  passwordHash   String?
  googleId       String?     @unique
  isPlatformAdmin Boolean    @default(false) // app operator, not settable via any API — flipped manually
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  membership     Membership?
  passwordResetTokens PasswordResetToken[]
}

model Account {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  disabledAt     DateTime?       // set by a platform admin; blocks all account access when non-null
  memberships    Membership[]
  emailThreads   EmailThread[]
  eventDocuments EventDocument[]
  accountData    AccountData?
  supportThreads SupportThread[]
}

model Membership {
  id          String   @id @default(cuid())
  role        String   @default("member") // 'owner' | 'admin' | 'member'
  permissions Json     @default("{}")
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
}

// Raw token is emailed to the user and never stored — only its hash, so a
// DB read alone can't be replayed to take over an account (same reasoning
// as passwordHash on User).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
}

// Contractors/events themselves still live in the frontend's localStorage
// (see server/README.md) — eventId/contractorId below are opaque strings
// from that blob, not real FKs. accountId is the only real relation, and is
// what scopes every read so different EVL accounts never see each other's
// threads.
model EmailThread {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  eventId         String
  contractorId    String
  contractorEmail String

  // "reply+<this.id>@<RESEND_INBOUND_DOMAIN>" — null until a domain is
  // configured. Set once and never recomputed, since a contractor's mail
  // client keeps replying to whatever address a past email actually had.
  replyToAlias    String?
  subjectHint     String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())

  messages        EmailMessage[]

  @@unique([accountId, eventId, contractorId])
  @@index([accountId])
}

model EmailMessage {
  id              String      @id @default(cuid())
  threadId        String
  thread          EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction       String      // 'outbound' | 'inbound'
  fromAddress     String
  toAddress       String
  subject         String
  body            String      @db.Text

  templateId      String?
  sentByUserId    String?
  resendMessageId String?     @unique
  inReplyTo       String?
  references      String?

  readAt          DateTime?   // inbound-only; null = unread
  createdAt       DateTime    @default(now())

  @@index([threadId, createdAt])
}

// The team's shared contractors/clients/events/bookings/settings, as a
// single JSON blob per account (mirrors the shape the frontend used to keep
// in localStorage, keyed by userId — now shared across every member of the
// account instead of siloed per browser).
model AccountData {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime @updatedAt
}

// Two-way support conversation between an account and the platform admin —
// deliberately mirrors EmailThread/EmailMessage's shape (direction as a
// plain string, accountId scoping, lastMessageAt/readAt) since that's this
// codebase's established pattern for threaded messages.
model SupportThread {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  subject       String
  status        String   @default("open") // 'open' | 'closed'
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages      SupportMessage[]

  @@index([accountId])
}

model SupportMessage {
  id           String        @id @default(cuid())
  threadId     String
  thread       SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction    String        // 'user' | 'admin'
  senderUserId String
  body         String        @db.Text

  readAt       DateTime?     // null = unread by the other side
  createdAt    DateTime      @default(now())

  @@index([threadId, createdAt])
}

// Uploaded reference documents (stage plots, floor plans, contracts) for an
// event's prep sheet. Stored directly in Postgres (Bytes) rather than an
// external object store — no new service to configure, fine at this scale.
model EventDocument {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  eventId     String   // opaque localStorage id, same non-FK pattern as EmailThread
  filename    String
  contentType String
  size        Int
  data        Bytes

  createdAt   DateTime @default(now())

  @@index([accountId, eventId])
}
