DATABASE_URL="postgresql://user:password@host:5432/dbname"
SESSION_SECRET="change-me-to-something-random"
PORT=4000
NODE_ENV="development"
# Comma-separated list of extra allowed frontend origins, e.g. deployed static hosts.
# Local dev on any localhost/127.0.0.1 port is always allowed automatically.
EXTRA_CLIENT_ORIGINS=""

RESEND_API_KEY=""
# Sandbox sender until a domain is verified in Resend — can only deliver to
# the Resend account's own signup email. Swap to an address on your verified
# domain (e.g. outreach@yourdomain.com) once that's set up.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Enables inbound replies on gig-inquiry email threads (server/src/routes/emailWebhooks.js).
# Requires the domain's MX record configured for receiving in Resend's
# dashboard (Domains > your domain > Inbound), plus a webhook there
# (Webhooks > Add webhook) pointed at <this server's URL>/api/webhooks/resend
# listening for the email.received event, whose signing secret goes below.
RESEND_INBOUND_DOMAIN=""
RESEND_WEBHOOK_SECRET=""

# Base URL of the deployed frontend — used to build the link inside
# password-reset emails. Defaults to local dev if unset.
FRONTEND_URL="http://localhost:5173"

# Where new support messages notify the platform admin. Change as
# hosting/business details evolve — not tied to any account.
SUPPORT_NOTIFICATION_EMAIL="shayalieberman@gmail.com"
